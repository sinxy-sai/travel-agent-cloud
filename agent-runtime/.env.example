APP_NAME=Travel Agent Runtime
APP_ENV=local
ALLOWED_ORIGINS=http://localhost:5173
RPC_TIMEOUT_SECONDS=5
DATABASE_URL=postgresql://travel_agent:travel_agent_dev@postgres:5432/travel_agent_cloud
RAG_ENABLED=true

# Runtime only verifies tokens forwarded by internal services; auth issuance lives in services/auth.
AUTH_SECRET_KEY=change-me-to-a-random-secret

LLM_PROVIDER=mock
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=deepseek-v4-flash
LLM_TEMPERATURE=0.4
LLM_MAX_TOKENS=1200
LLM_TIMEOUT_SECONDS=30
# basic is stable; langgraph uses compiled LangGraph and optional LangChain tool-calling nodes when LLM settings are configured
AGENT_ENGINE=basic
TRAVEL_TOOL_PROVIDER=mock
FASTMCP_BASE_URL=http://travel-mcp:8100/mcp
FASTMCP_AUTH_TOKEN=
FASTMCP_TIMEOUT_SECONDS=8
FASTMCP_ATTRACTIONS_TOOL=travel.search_attractions
FASTMCP_HOTEL_TOOL=travel.search_hotel
FASTMCP_MEALS_TOOL=travel.search_meals
FASTMCP_ROUTES_TOOL=travel.plan_routes
FASTMCP_WEATHER_TOOL=travel.get_weather
FASTMCP_BUDGET_TOOL=travel.estimate_budget
WEB_RESEARCH_ENABLED=true
# Optional. Example: http://searxng:8080. Empty value uses built-in destination research notes.
SEARXNG_BASE_URL=http://searxng:8080
WEB_RESEARCH_TIMEOUT_SECONDS=6
WEB_RESEARCH_MAX_RESULTS=4
WEB_RESEARCH_LANGUAGE=auto
INTERNAL_SERVICE_TOKEN=change-me-internal-service-token
LOG_LEVEL=INFO

OTEL_ENABLED=false
OTEL_SERVICE_NAMESPACE=travel-agent-cloud
OTEL_EXPORTER_OTLP_ENDPOINT=http://tempo:4318
