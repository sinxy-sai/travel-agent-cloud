APP_NAME=Travel Agent Runtime
APP_ENV=local
ALLOWED_ORIGINS=http://localhost:5173
DATABASE_URL=postgresql://travel_agent:travel_agent_dev@postgres:5432/travel_agent_cloud
MESSAGE_QUEUE_URL=amqp://travel_agent:travel_agent_dev@rabbitmq:5672/
REDIS_URL=redis://redis:6379/0
REDIS_KEY_PREFIX=travel-agent-cloud

# Legacy compatibility only. New account export files are owned by services/travel-auth.
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=travel_agent
MINIO_SECRET_KEY=travel_agent_dev_secret
MINIO_BUCKET=travel-agent-exports
MINIO_SECURE=false
RPC_TIMEOUT_SECONDS=5
WORKER_RECONNECT_INITIAL_SECONDS=2
WORKER_RECONNECT_MAX_SECONDS=30

# Legacy compatibility only. New auth/profile APIs are owned by services/travel-auth.
AUTH_SECRET_KEY=change-me-to-a-random-secret
AUTH_TOKEN_TTL_SECONDS=604800
AUTH_COOKIE_SECURE=false
AUTH_RATE_LIMIT_MAX_ATTEMPTS=20
AUTH_RATE_LIMIT_WINDOW_SECONDS=900
EMAIL_PROVIDER=mock
EMAIL_FROM=no-reply@travel-agent-cloud.local
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_SSL=false
SMTP_STARTTLS=true
PUBLIC_APP_URL=http://localhost:5173
EMAIL_VERIFICATION_TOKEN_TTL_SECONDS=86400
PASSWORD_RESET_TOKEN_TTL_SECONDS=1800
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=http://localhost:8000/api/v1/auth/oauth/github/callback
OAUTH_HTTP_TIMEOUT_SECONDS=10
LLM_PROVIDER=mock
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=deepseek-v4-flash
LLM_TEMPERATURE=0.4
LLM_MAX_TOKENS=1200
LLM_TIMEOUT_SECONDS=30
# basic is stable; langgraph uses compiled LangGraph and optional LangChain tool-calling nodes when LLM settings are configured
AGENT_ENGINE=basic
TRAVEL_TOOL_PROVIDER=mock
FASTMCP_BASE_URL=http://travel-mcp:8100/mcp
FASTMCP_AUTH_TOKEN=
FASTMCP_TIMEOUT_SECONDS=8
FASTMCP_ATTRACTIONS_TOOL=travel.search_attractions
FASTMCP_HOTEL_TOOL=travel.search_hotel
FASTMCP_MEALS_TOOL=travel.search_meals
FASTMCP_ROUTES_TOOL=travel.plan_routes
FASTMCP_WEATHER_TOOL=travel.get_weather
FASTMCP_BUDGET_TOOL=travel.estimate_budget
TRAVEL_TRIP_URL=http://travel-trip:8200
TRAVEL_TRIP_TIMEOUT_SECONDS=10
LOG_LEVEL=INFO
